<mujoco model="biped_rl_actuator">

    <compiler angle="radian" autolimits="true"/>

    <option timestep="0.002"
            gravity="0 0 -9.81"
            integrator="RK4"
            solver="Newton"
            iterations="80"
            ls_iterations="20"
            cone="elliptic"/>

    <default>
        <!-- AK10-9: реалистичные параметры для joint'ов (будут переопределены) -->
        <joint damping="0.5"
               armature="0.01"
               frictionloss="0.3"/>

        <geom contype="1"
              conaffinity="1"
              condim="6"
              friction="2.0 0.05 0.01"
              solref="0.003 1"
              solimp="0.95 0.99 0.001"/>

        <motor ctrllimited="true"
               ctrlrange="-18 18"/>
    </default>

    <asset>
        <texture type="skybox"
                 builtin="gradient"
                 rgb1="0.6 0.8 1.0"
                 rgb2="0.2 0.4 0.7"
                 width="256"
                 height="256"/>

        <texture name="grid"
                 type="2d"
                 builtin="checker"
                 rgb1="0.55 0.55 0.55"
                 rgb2="0.4 0.4 0.4"
                 width="512"
                 height="512"/>

        <material name="floor_mat"
                  texture="grid"
                  texrepeat="5 5"/>

        <material name="torso_mat"
                  rgba="0.2 0.4 0.8 1"/>

        <material name="thigh_mat"
                  rgba="0.1 0.7 0.3 1"/>

        <material name="shank_mat"
                  rgba="0.8 0.5 0.1 1"/>

        <material name="wheel_mat"
                  rgba="0.1 0.1 0.1 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 3"
               dir="0 0 -1"
               diffuse="0.9 0.9 0.9"/>

        <geom name="floor"
              type="plane"
              size="10 10 0.1"
              material="floor_mat"/>

        <body name="torso" pos="0 0 0.74">
            <freejoint name="root"/>

            <inertial pos="0 0 0"
                      mass="3.0"
                      diaginertia="0.08 0.07 0.05"/>

            <geom name="torso_geom"
                  type="box"
                  size="0.10 0.18 0.15"
                  density="500"
                  material="torso_mat"/>

            <site name="imu"
                  pos="0 0 0"
                  size="0.01"/>

            <body name="L_thigh" pos="0 0.18 -0.15">
                <!-- Реалистичные параметры для бедра -->
                <joint name="L_hip"
                       type="hinge"
                       axis="0 1 0"
                       range="-0.8 0.8"
                       damping="0.5"
                       armature="0.01"
                       frictionloss="0.3"/>

                <inertial pos="0 0 -0.15"
                          mass="1.5"
                          diaginertia="0.015 0.015 0.004"/>

                <geom name="L_thigh_geom"
                      type="capsule"
                      fromto="0 0 0 0 0 -0.22"
                      size="0.035"
                      density="700"
                      material="thigh_mat"/>

                <body name="L_shank" pos="0 0 -0.22">
                    <!-- Реалистичные параметры для колена -->
                    <joint name="L_knee"
                           type="hinge"
                           axis="0 1 0"
                           range="0.0 2.0"
                           damping="0.5"
                           armature="0.01"
                           frictionloss="0.3"/>

                    <inertial pos="0 0 -0.15"
                              mass="0.8"
                              diaginertia="0.008 0.008 0.002"/>

                    <geom name="L_shank_geom"
                          type="capsule"
                          fromto="0 0 0 0 0 -0.22"
                          size="0.028"
                          density="700"
                          material="shank_mat"/>

                    <body name="L_wheel" pos="0 0 -0.22">
                        <!-- Колесо: небольшое вязкое трение, инерция ротора 0.01, сухое трение 0 -->
                        <joint name="L_wheel_j"
                               type="hinge"
                               axis="0 1 0"
                               limited="false"
                               damping="0.05"
                               armature="0.01"
                               frictionloss="0.0"/>

                        <inertial pos="0 0 0"
                                  mass="0.5"
                                  diaginertia="0.003 0.005 0.005"/>

                        <geom name="L_tire"
                              type="cylinder"
                              size="0.10 0.03"
                              euler="1.5708 0 0"
                              material="wheel_mat"
                              friction="1.2 0.02 0.01"
                              condim="6"
                              density="900"/>

                        <site name="L_ct"
                              pos="0 0 0"
                              size="0.01"/>
                    </body>
                </body>
            </body>

            <body name="R_thigh" pos="0 -0.18 -0.15">
                <joint name="R_hip"
                       type="hinge"
                       axis="0 1 0"
                       range="-0.8 0.8"
                       damping="0.5"
                       armature="0.01"
                       frictionloss="0.3"/>

                <inertial pos="0 0 -0.15"
                          mass="1.5"
                          diaginertia="0.015 0.015 0.004"/>

                <geom name="R_thigh_geom"
                      type="capsule"
                      fromto="0 0 0 0 0 -0.22"
                      size="0.035"
                      density="700"
                      material="thigh_mat"/>

                <body name="R_shank" pos="0 0 -0.22">
                    <joint name="R_knee"
                           type="hinge"
                           axis="0 1 0"
                           range="0.0 2.0"
                           damping="0.5"
                           armature="0.01"
                           frictionloss="0.3"/>

                    <inertial pos="0 0 -0.15"
                              mass="0.8"
                              diaginertia="0.008 0.008 0.002"/>

                    <geom name="R_shank_geom"
                          type="capsule"
                          fromto="0 0 0 0 0 -0.22"
                          size="0.028"
                          density="700"
                          material="shank_mat"/>

                    <body name="R_wheel" pos="0 0 -0.22">
                        <joint name="R_wheel_j"
                               type="hinge"
                               axis="0 1 0"
                               limited="false"
                               damping="0.05"
                               armature="0.01"
                               frictionloss="0.0"/>

                        <inertial pos="0 0 0"
                                  mass="0.5"
                                  diaginertia="0.003 0.005 0.005"/>

                        <geom name="R_tire"
                              type="cylinder"
                              size="0.10 0.03"
                              euler="1.5708 0 0"
                              material="wheel_mat"
                              friction="1.2 0.02 0.01"
                              condim="6"
                              density="900"/>

                        <site name="R_ct"
                              pos="0 0 0"
                              size="0.01"/>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="L_hip_m"
               joint="L_hip"
               gear="3"
               ctrllimited="true"
               ctrlrange="-18 18"/>

        <motor name="R_hip_m"
               joint="R_hip"
               gear="3"
               ctrllimited="true"
               ctrlrange="-18 18"/>

        <motor name="L_knee_m"
               joint="L_knee"
               gear="3"
               ctrllimited="true"
               ctrlrange="-18 18"/>

        <motor name="R_knee_m"
               joint="R_knee"
               gear="3"
               ctrllimited="true"
               ctrlrange="-18 18"/>

        <motor name="L_wheel_m"
               joint="L_wheel_j"
               gear="3"
               ctrllimited="true"
               ctrlrange="-18 18"/>

        <motor name="R_wheel_m"
               joint="R_wheel_j"
               gear="3"
               ctrllimited="true"
               ctrlrange="-18 18"/>
    </actuator>

    <sensor>
        <accelerometer name="imu_acc" site="imu"/>
        <gyro          name="imu_gyro" site="imu"/>

        <jointpos name="L_hip_pos"  joint="L_hip"/>
        <jointvel name="L_hip_vel"  joint="L_hip"/>

        <jointpos name="L_knee_pos" joint="L_knee"/>
        <jointvel name="L_knee_vel" joint="L_knee"/>

        <jointpos name="R_hip_pos"  joint="R_hip"/>
        <jointvel name="R_hip_vel"  joint="R_hip"/>

        <jointpos name="R_knee_pos" joint="R_knee"/>
        <jointvel name="R_knee_vel" joint="R_knee"/>

        <actuatorfrc name="L_hip_frc"
                     actuator="L_hip_m"/>
        <actuatorfrc name="L_knee_frc"
                     actuator="L_knee_m"/>
        <actuatorfrc name="R_hip_frc"
                     actuator="R_hip_m"/>
        <actuatorfrc name="R_knee_frc"
                     actuator="R_knee_m"/>

        <touch name="L_contact" site="L_ct"/>
        <touch name="R_contact" site="R_ct"/>
    </sensor>

</mujoco>
